# === Auth (protect the MCP endpoint in HTTP mode) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_TOKEN=REPLACE_WITH_YOUR_32_CHAR_MIN_TOKEN

# === SerpAPI (Google Flights search) ===
# Sign up at https://serpapi.com — free tier: 100 searches/month
# Dashboard: https://serpapi.com/dashboard
SERPAPI_KEY=your_serpapi_key_here

# === Server (HTTP mode only) ===
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# === Price Tracking ===
PRICE_TRACKER_PATH=./data/price-tracker.json
